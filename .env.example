# ── Source: course platform Postgres (READ-ONLY user, SSL) ──────────
SOURCE_PG_HOST=your-prod-host
SOURCE_PG_PORT=5432
SOURCE_PG_DB=course_platform
SOURCE_PG_USER=analytics_ro          # read-only, SELECT on needed tables only
SOURCE_PG_PASSWORD=change-me
SOURCE_PG_SSLMODE=require

# ── DuckLake catalog Postgres (runs in infra/docker-compose.yml) ────
CATALOG_PG_HOST=localhost
CATALOG_PG_PORT=5433
CATALOG_PG_DB=ducklake_catalog
CATALOG_PG_USER=ducklake
CATALOG_PG_PASSWORD=change-me

# ── Lake storage ────────────────────────────────────────────────────
LAKE_DATA_PATH=/data/lake            # Parquet files live here on the VPS

# ── Alerting (Phase 4) ──────────────────────────────────────────────
ALERT_WEBHOOK_URL=
