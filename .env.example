# Machine truth — copy to .env and set YOUR absolute paths (.env is gitignored).
# Plain KEY=VALUE, no shell expansion: literal absolute paths.
# Read by: just (dotenv-load) · dbt ({{ env_var('...') }}) · dlt (double-underscore keys)

LAKE_CATALOG=/absolute/path/to/repo/data/lake_catalog.ducklake
DESTINATION__DUCKLAKE__CREDENTIALS__STORAGE__BUCKET_URL=file:///absolute/path/to/repo/data/lake_files/
DESTINATION__DUCKLAKE__CREDENTIALS__CATALOG=duckdb:////absolute/path/to/repo/data/lake_catalog.ducklake
